{
  "name": "desktop",
  "productName": "OpenHarness",
  "version": "0.2.1",
  "description": "Desktop harness for Pi coding agents",
  "author": "OpenHarness",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "node ../../scripts/check-pi-vendor.mjs && electron-vite dev",
    "prebuild": "pnpm --filter @openharness/pi-rpc build",
    "build": "electron-vite build",
    "stage:pi": "node ../../scripts/stage-pi-runtime.mjs",
    "stage:node": "node ../../scripts/stage-node-runtime.mjs",
    "dist": "pnpm run stage:node && pnpm run stage:pi && pnpm run build && electron-builder --config electron-builder.yml",
    "dist:publish": "pnpm run stage:node && pnpm run stage:pi && pnpm run build && electron-builder --config electron-builder.yml --publish always",
    "dist:dir": "pnpm run stage:node && pnpm run stage:pi && pnpm run build && electron-builder --config electron-builder.yml --dir",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@openharness/pi-rpc": "workspace:*",
    "@radix-ui/react-tooltip": "^1.2.9",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.9",
    "fast-glob": "^3.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "slot-text": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.1",
    "autoprefixer": "^10.4.21",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
