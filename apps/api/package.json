{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @openharness/db build && tsx watch src/dev.ts",
    "build": "pnpm --filter @openharness/db build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/github/workflow-comment-filter.test.ts src/github/workflow-trigger-match.test.ts",
    "auth:generate": "better-auth generate --config ./src/auth.ts --output ../../packages/db/src/schema/auth.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.19",
    "@better-auth/electron": "^1.6.19",
    "@hono/node-server": "^1.19.6",
    "@openharness/db": "workspace:*",
    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.10.7"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/node": "^22.15.29",
    "dotenv": "^16.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
