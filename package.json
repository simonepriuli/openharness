{
  "name": "openharness",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=desktop",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build": "turbo build",
    "build:pi": "pnpm --filter @openharness/pi-vendor build",
    "stage:pi": "node scripts/stage-pi-runtime.mjs",
    "stage:node": "node scripts/stage-node-runtime.mjs",
    "dist": "pnpm --filter desktop dist",
    "dist:local": "pnpm --filter desktop dist:local",
    "typecheck": "turbo typecheck",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "postinstall": "node scripts/postinstall-pi.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"],
    "overrides": {
      "drizzle-orm": "^0.45.2"
    }
  }
}
