{
  "name": "@openharness/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:orgs": "node --import tsx ./scripts/migrate-organizations.ts",
    "db:invite-codes": "node --import tsx ./scripts/backfill-invite-codes.ts",
    "db:repo-bindings": "node --import tsx ./scripts/migrate-repo-bindings.ts",
    "db:source-control": "node --import tsx ./scripts/migrate-github-to-source-control.ts",
    "db:org-secrets": "node --import tsx ./scripts/apply-sql-file.ts ./drizzle/0012_organization_secret.sql",
    "db:linear-agent-run-events": "node --import tsx ./scripts/apply-sql-file.ts ./drizzle/0017_linear_agent_run_event.sql",
    "db:linear-agent-issue-workspace": "node --import tsx ./scripts/apply-sql-file.ts ./drizzle/0018_linear_agent_issue_workspace.sql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
