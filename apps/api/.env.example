# Copy to apps/api/.env and fill in values from Neon + GitHub OAuth app.
#
# Local dev:
#   pnpm --filter @openharness/db build
#   cp apps/api/.env.example apps/api/.env
#   pnpm dev:api
#
# Apply schema to Neon (reads DATABASE_URL from this file):
#   pnpm --filter @openharness/db db:push
#
# Incremental SQL migrations (when db:push fails or for one-off files):
#   pnpm --filter @openharness/db db:linear-agent-run-events

# Neon pooled connection string (serverless)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated origins allowed to call the API (desktop dev, web sign-in, production).
# The Electron deep-link scheme (com.openharness.desktop:/) is added automatically.
TRUSTED_ORIGINS=http://localhost:3001,http://localhost:5173

# Vercel Cron auth for scheduled workflow ticks (GET /api/cron/workflow-scheduler).
# Also used by GET /api/cron/linear-agent-workspaces (stops idle issue sandboxes).
# Set the same value in Vercel project env; Vercel sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=generate-with-openssl-rand-base64-32

# Idle TTL (minutes) for issue-scoped Linear agent sandboxes after last completed run.
# Default 45; clamped to 30–120. Sandboxes are stopped when expired.
# LINEAR_AGENT_ISSUE_WORKSPACE_IDLE_TTL_MINUTES=45

# Cloud workers
CLOUD_WORKER_SECRET=generate-with-openssl-rand-base64-32

# Cloud worker snapshot for production cloud dispatch (from pnpm snapshot:cloud-worker in apps/api).
CLOUD_WORKER_SNAPSHOT_ID=

# Must match the bundle fingerprint embedded in the API build and staged sandbox manifest.
# Set automatically by the Cloud Worker Snapshot GitHub Actions workflow.
CLOUD_WORKER_BUNDLE_FINGERPRINT=

# Local snapshot script auth (apps/api/.env.local — gitignored). Pick one method:
#
# A) Recommended: link the API Vercel project, then pull OIDC token:
#    cd apps/api && vercel link && vercel env pull .env.local
#    (writes VERCEL_OIDC_TOKEN; refresh every ~12h with vercel env pull)
#
# B) Personal access token (team-scoped token from https://vercel.com/account/settings/tokens):
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=        # Team Settings → General
# VERCEL_PROJECT_ID=     # Project Settings → General (API project)

# GitHub OAuth app (https://github.com/settings/developers) — OpenHarness login only
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenHarness GitHub App (https://github.com/settings/apps) — repo access and bot actions
# Permissions: Pull requests R/W, Issues R/W, Metadata R, Contents R/W (for push via local git)
# Webhook events: installation, installation_repositories, pull_request, pull_request_review, issue_comment, pull_request_review_comment
# Comment fixer reacts to pull_request_review (submitted); issue_comment is optional for other features.
# Setup URL: {BETTER_AUTH_URL}/api/github/install/callback
# Webhook URL: {BETTER_AUTH_URL}/api/github/webhook
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_SLUG=

# Azure DevOps (source control) — org-level PAT for repo access, PR actions, and service hooks.
# Use a dedicated service account; workflow comments and approvals appear as that ADO user (not a bot).
# Create a PAT with: Code R/W, Pull Request R/W, Project Read, Service Hooks R/W.
# Webhook URL (auto-provisioned on repo link): {BETTER_AUTH_URL}/api/azure-devops/webhook
# PR/workflow APIs: {BETTER_AUTH_URL}/api/source-control/pr/azure_devops/...

# Azure bot for MS Teams integration
TEAMS_BOT_APP_ID=...
TEAMS_BOT_APP_SECRET=...
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...
MICROSOFT_OAUTH_REDIRECT_URI=https://<your-api>/api/teams/oauth/callback

# Discord bot + OAuth integration
# OAuth redirect URI: {BETTER_AUTH_URL}/api/discord/oauth/callback
# Public key is used to verify interaction signatures from Discord.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=