{
  "name": "openharness",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=desktop",
    "dev:api": "pnpm --filter api dev",
    "dev:cloud-worker": "pnpm --filter cloud-worker dev",
    "dev:web": "pnpm --filter web dev",
    "dev:docs": "pnpm --filter docs dev",
    "build": "turbo build",
    "build:pi": "pnpm --filter @openharness/pi-vendor build",
    "stage:pi": "node scripts/stage-pi-runtime.mjs",
    "sync:pi-sha": "node scripts/sync-vendor-pi-sha.mjs",
    "stage:cloud-worker": "node scripts/stage-cloud-worker-runtime.mjs",
    "stage:node": "node scripts/stage-node-runtime.mjs",
    "dist": "pnpm --filter desktop dist",
    "dist:local": "pnpm --filter desktop dist:local",
    "typecheck": "turbo typecheck",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "postinstall": "node scripts/postinstall-pi.mjs",
    "prepare": "node scripts/install-githooks.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"],
    "overrides": {
      "@vercel/sandbox": "2.4.0",
      "drizzle-orm": "^0.45.2",
      "@better-auth/core": "1.6.19",
      "@better-auth/utils": "0.4.2",
      "@better-fetch/fetch": "1.3.1",
      "better-call": "1.3.6",
      "kysely": "0.29.2"
    }
  }
}
